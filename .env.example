NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_ENTRY=src/server.mjs
DB_PATH=data/app.db
LOG_LEVEL=info

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
SESSION_SECRET=change-me-session-secret
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
ACCOUNT_CREDENTIALS_SECRET=change-me-account-credentials-secret

AUTO_COLLECT_ENABLED=true
COLLECTOR_TICK_MS=60000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Utility account credentials are configured in the admin web UI.
# Do not put water / electricity / gas account usernames, passwords,
# cookies, tokens, or storage snapshots in environment variables.

# Optional advanced runtime overrides. In most deployments you can leave them unset.
# SGCC_TIMEOUT_MS=60000
# HZWATER_TIMEOUT_MS=30000
# HZGAS_TIMEOUT_MS=30000
